# Twinfield OAuth2 credentials — register a client via the Twinfield Developer Portal
TWINFIELD_CLIENT_ID=
TWINFIELD_CLIENT_SECRET=

# Refresh token obtained via the one-time `npm run authorize` flow (Phase 1)
TWINFIELD_REFRESH_TOKEN=

# The Twinfield office (CompanyCode) to use by default, e.g. "DEMO123"
TWINFIELD_OFFICE_CODE=

# Optional explicit path to the multi-office credentials JSON file
# Default precedence: TWINFIELD_CREDENTIALS_FILE → ~/.twinfield/credentials.json → ./credentials.json
TWINFIELD_CREDENTIALS_FILE=

# Anthropic API key — only required for the test-agent script (npm run agent)
ANTHROPIC_API_KEY=
